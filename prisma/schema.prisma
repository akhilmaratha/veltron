generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShippingMethod {
  standard
  express
}

enum PaymentStatus {
  pending
  paid
  packed
  shipped
  delivered
  failed
  refunded
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  provider      String?
  role          String    @default("customer")
  resetTokens   PasswordResetToken[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([provider])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Order {
  id                String         @id @default(cuid())
  razorpayOrderId   String         @unique
  razorpayPaymentId String         @unique
  amount            Int
  currency          String
  shippingMethod    ShippingMethod
  paymentStatus     PaymentStatus  @default(paid)
  customerFirstName String
  customerLastName  String
  customerEmail     String
  customerAddress   String
  customerCity      String
  customerPostalCode String
  customerCountry   String
  items             OrderItem[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  name        String
  variant     String
  unitPrice   Int
  quantity    Int
  lineTotal   Int
  image       String?
  createdAt   DateTime @default(now())

  @@index([orderId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  slug        String   @unique
  brand       String?
  category    String
  priceCents  Int
  stock       Int
  imageUrl    String
  description String
  badge       String?
  isFeatured  Boolean  @default(false)
  isNewArrival Boolean @default(false)
  isBestseller Boolean @default(false)
  rating      Float?
  reviewCount Int?
  tags        String[] @default([])
  galleryImages String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
  @@index([slug])
}

model WebhookLog {
  id                String   @id @default(cuid())
  provider          String
  eventId           String   @unique
  eventType         String
  referenceId       String
  payload           String
  status            String   @default("processed")
  processedAt       DateTime @default(now())
  
  @@index([provider])
  @@index([eventId])
  @@index([processedAt])
}

model HeroSlide {
  id          String   @id @default(cuid())
  eyebrow     String
  title       String
  description String
  ctaLabel    String
  ctaUrl      String
  imageUrl    String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@index([startsAt, endsAt])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  imageUrl    String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}