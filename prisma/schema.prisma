generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShippingMethod {
  standard
  express
}

enum PaymentStatus {
  paid
  failed
  refunded
}

model Order {
  id                String         @id @default(cuid())
  razorpayOrderId   String         @unique
  razorpayPaymentId String         @unique
  amount            Int
  currency          String
  shippingMethod    ShippingMethod
  paymentStatus     PaymentStatus  @default(paid)
  customerFirstName String
  customerLastName  String
  customerEmail     String
  customerAddress   String
  customerCity      String
  customerPostalCode String
  customerCountry   String
  items             OrderItem[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  name        String
  variant     String
  unitPrice   Int
  quantity    Int
  lineTotal   Int
  image       String?
  createdAt   DateTime @default(now())

  @@index([orderId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  category    String
  priceCents  Int
  stock       Int
  imageUrl    String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
}